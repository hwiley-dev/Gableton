{
  "name": "gableton-desktop",
  "private": true,
  "version": "0.1.0",
  "description": "Desktop collaboration client for Ableton Live projects.",
  "author": "Hunter Wiley",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite --host 127.0.0.1 --port 4174",
    "dev:api": "node scripts/dev-api.mjs",
    "dev:desktop": "concurrently -k \"npm run dev:api\" \"npm run dev:web\" \"wait-on tcp:127.0.0.1:4174 && electron electron/main.mjs\"",
    "smoke:api": "node scripts/smoke-phase1-api.mjs",
    "build": "vite build",
    "build:web": "vite build",
    "build:desktop": "npm run build:web && electron-builder --dir",
    "dist:mac": "npm run build:web && electron-builder --mac dmg",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^9.1.2",
    "electron": "^36.2.1",
    "electron-builder": "^26.0.12",
    "typescript": "^5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^8.0.3"
  }
}
